---
interface Props {
  title: string;
  subtitle?: string;
  breadcrumb?: { text: string; href: string }[];
}

const { title, subtitle, breadcrumb } = Astro.props;

// Construct the Schema.org JSON-LD for Breadcrumbs
// Position 1 is always Home, subsequent items follow the breadcrumb array
const breadcrumbSchema = breadcrumb ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": Astro.site?.href
    },
    ...breadcrumb.map((crumb, index) => ({
      "@type": "ListItem",
      "position": index + 2,
      "name": crumb.text,
      "item": new URL(crumb.href, Astro.site).href
    }))
  ]
} : null;
---

<!-- Breadcrumb Schema -->
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}

<div class="mb-8 border-b border-gray-200 pb-4">
  {breadcrumb && (
    <nav class="flex items-center text-sm text-gray-500 mb-4" aria-label="Breadcrumb">
      <a href="/" class="hover:text-schiketanz-red transition-colors">Home</a>
      {breadcrumb.map((crumb) => (
        <>
          <span class="mx-2 text-gray-300">/</span>
          <a href={crumb.href} class="hover:text-schiketanz-red transition-colors">
            {crumb.text}
          </a>
        </>
      ))}
    </nav>
  )}

  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
      <h1 class="font-century font-bold text-[clamp(2rem,5vw,2.5rem)] text-balance text-schiketanz-red leading-tight">
        {title}
      </h1>
      {subtitle && (
        <p class="text-gray-600 text-lg mt-2 text-pretty font-sans">
          {subtitle}
        </p>
      )}
    </div>
    <slot name="after-title" />
  </div>
</div>
---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageContainer from '../components/PageContainer.astro';
import PropertyGallery from '../components/PropertyGallery.astro';
import type { ImageMetadata } from 'astro';

// dynamically import all images from commercial folder
const imageFiles = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/commercial/forest-hill/*.{jpeg,jpg,png,gif,webp,avif}', 
  { eager: true }
);
// convert imported object into a clean array of images
const images = Object.values(imageFiles).map((file) => file.default);
---

<Layout title="Commercial Leasing | Schiketanz Real Estate">
  <PageContainer>
    <PageHeader 
      title="Commercial Properties" 
      subtitle="Retail and office space management in the Kitchener-Waterloo region."
      breadcrumb={[{ text: 'Commercial', href: '/commercial' }]}
    />
    <article class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
        <!-- Image Gallery Container -->
        <div class="w-full flex flex-col h-fit">
            {images.length > 0 ? (
                <PropertyGallery images={images} title="Forest Hill Shopping Centre" />
            ) : (
                <div class="bg-gray-200 aspect-video w-full rounded-sm flex items-center justify-center text-gray-500 border border-gray-300">
                    <span class="font-century">Forest Hill Shopping Centre Photos</span>
                </div>
            )}
        </div>
        <!-- Content -->
        <div class="flex flex-col justify-center">
            <h2 class="font-century font-bold text-3xl text-gray-800 mb-2">Forest Hill Shopping Centre</h2>
            <p class="text-gray-500 text-lg mb-6">395-421 Greenbrook Drive, Kitchener, Ontario</p>

            <div class="prose text-gray-700 mb-8">
                <p>
                    Forest Hill Shopping Centre is centrally located in the Forest Hill Area of Kitchener, Ontario. This shopping centre meets everyone's needs.
                </p>
                <p>
                    It includes a Giant Tiger, pharmacy, restaurant, bakery, doctors and dentists offices and so much more!
                </p>
                <ul class="list-disc pl-5 space-y-2 mt-4">
                    <li>High traffic visibility</li>
                    <li>Ample parking for customers</li>
                    <li>Professional property management on-site</li>
                </ul>
            </div>
            <div class="bg-gray-50 p-6 border-l-4 border-schiketanz-red max-w-md w-fit pr-10">
                <h3 class="font-bold text-gray-800 mb-2">Leasing Inquiries</h3>
                <p class="text-gray-600 mb-4">
                    For information on space available for rent, please contact Sue.
                </p>
                <div class="space-y-2">
                    <a href="tel:5197424477" class="block font-bold text-gray-800 hover:text-schiketanz-red transition-colors">(519) 742-4477</a>
                    <a href="mailto:sue@schiketanz.ca" class="block text-schiketanz-red font-bold hover:underline">
                        sue@schiketanz.ca &rarr;
                    </a>
                </div>
            </div>
        </div>
    </article>
  </PageContainer>
</Layout>